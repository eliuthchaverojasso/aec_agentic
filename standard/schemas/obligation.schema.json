{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aec-control-plane.local/schemas/obligation.schema.json",
  "title": "Executable Obligation",
  "type": "object",
  "required": ["id", "source_reference", "issuer", "obligated_party", "statement", "status"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "source_reference": { "$ref": "./shared.schema.json#/$defs/entity_ref" },
    "issuer": { "$ref": "./shared.schema.json#/$defs/entity_ref" },
    "obligated_party": { "$ref": "./shared.schema.json#/$defs/entity_ref" },
    "statement": { "type": "string", "minLength": 1 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "affected_scope": { "type": "array", "items": { "$ref": "./shared.schema.json#/$defs/entity_ref" } },
    "affected_assets": { "type": "array", "items": { "$ref": "./shared.schema.json#/$defs/entity_ref" } },
    "required_evidence": { "type": "array", "items": { "type": "string" } },
    "required_reviewer": { "$ref": "./shared.schema.json#/$defs/entity_ref" },
    "approval_authority": { "$ref": "./shared.schema.json#/$defs/entity_ref" },
    "status": {
      "enum": [
        "discovered",
        "classified",
        "accepted",
        "allocated",
        "in_progress",
        "claimed_satisfied",
        "verified",
        "approved",
        "superseded",
        "rejected"
      ]
    },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}

